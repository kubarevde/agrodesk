# Production secrets for AgroDesk @ 213.183.104.142:3010
# Copy to .env.production and fill real values:
#   cp .env.production.example .env.production
#
# IMPORTANT: DATABASE_URL is built in docker-compose as postgresql+asyncpg://...

# --- Required ---
SECRET_KEY=change_me_to_a_long_random_string
BOT_INTERNAL_SECRET=change_me_too_shared_with_bot
BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
POSTGRES_PASSWORD=strong_unique_password_here
SUPERADMIN_EMAIL=admin@your-domain.tld
SUPERADMIN_PASSWORD=super_strong_password

# --- Database ---
POSTGRES_DB=agrodesk
POSTGRES_USER=agrodesk

# --- JWT / logging ---
JWT_EXPIRE_MINUTES=1440
LOG_LEVEL=INFO

# --- Frontend / API public URLs (nginx :3010) ---
API_URL=http://213.183.104.142:3010
ALLOWED_ORIGINS=http://213.183.104.142:3010,http://localhost:3010

# --- Optional ---
# Seed demo org/employees on API start (disable on real prod)
RUN_SEED_ON_START=false
SHEETS_MIRROR_ENABLED=false
ORG_ID=main
