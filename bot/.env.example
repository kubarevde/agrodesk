# =============================================================================
# AgroDesk Telegram Bot — env for bothost.ru (copy to panel or .env)
# Canonical names below; aliases BOTTOKEN/APIBASEURL/BOTINTERNALSECRET also work.
# =============================================================================

# --- Required ---
BOT_TOKEN=
API_BASE_URL=https://your-agrodesk-domain.ru
BOT_INTERNAL_SECRET=

# --- Production (bothost.ru) ---
AGRODESK_ENV=production
BOT_RUN_MODE=polling
LOG_LEVEL=INFO

# --- HTTP / resilience (RU networks) ---
REQUEST_TIMEOUT=15
REQUEST_RETRIES=2
TELEGRAM_TIMEOUT=60
POLLING_TIMEOUT=30

# --- Self-check (optional) ---
# SMOKE_TELEGRAM_ID=111111111

# --- Google Sheets mirror (optional, default off) ---
SHEETS_MIRROR_ENABLED=false
GOOGLE_SHEETS_NAME=worktime_bot
GOOGLE_CREDS_PATH=credentials/service_account.json
