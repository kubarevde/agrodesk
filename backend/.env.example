# Database
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/agrodesk

# JWT
SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=10080

# Logging
LOG_LEVEL=INFO

# Shared secret for Telegram bot → API auth
BOT_INTERNAL_SECRET=agrodesk-bot-secret-change-me

# Telegram Bot API token (empty = notifications skipped)
TELEGRAM_BOT_TOKEN=

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://storage.yandexcloud.net

# Local image uploads
UPLOADS_DIR=./uploads

# Public API base URL (for absolute image URLs in sharing listings)
API_URL=http://localhost:8000

# Optional bootstrap superadmin (created on API startup if table is empty)
SUPERADMIN_EMAIL=admin@agrodesk.local
SUPERADMIN_PASSWORD=ChangeMe123!

# Seed demo org/employees on API startup (also run: python -m app.seed)
RUN_SEED_ON_START=true
